{
  "name": "Recipe",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "title_ne": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cover_image": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "main",
        "snack",
        "dessert",
        "drink",
        "pickle"
      ],
      "default": "main"
    },
    "prep_time": {
      "type": "number"
    },
    "serves": {
      "type": "number"
    },
    "published": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "title"
  ]
}
