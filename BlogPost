{
  "name": "BlogPost",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "title_ne": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "cover_image": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "village",
        "culture",
        "personal",
        "travel",
        "other"
      ],
      "default": "personal"
    },
    "published": {
      "type": "boolean",
      "default": false
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "read_time": {
      "type": "number"
    }
  },
  "required": [
    "title",
    "content"
  ]
}
